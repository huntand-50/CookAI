# CookAI Configuration
# Скопируйте этот файл в .env и заполните значения

# === DATABASE ===
DB_HOST=localhost
DB_NAME=cookai_db
DB_USER=cookai_user
DB_PASSWORD=your_password
DB_PORT=3306
DB_CHARSET=utf8mb4

# === YANDEX AI API ===
YANDEX_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here
YANDEX_GPT_MODEL=yandexgpt-3
YANDEX_IMAGE_MODEL=yandex-image-generation

# === APPLICATION ===
APP_URL=http://localhost/CookAI/public
APP_NAME=CookAI
APP_ENV=development
APP_DEBUG=true

# === SESSION ===
SESSION_LIFETIME=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true

# === MAIL (опционально) ===
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USER=your_email
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@cookai.com

# === FILE UPLOADS ===
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf
UPLOAD_PATH=/storage/uploads

# === AI CACHE ===
AI_CACHE_ENABLED=true
AI_CACHE_TTL=86400
AI_RATE_LIMIT=100

# === LOGGING ===
LOG_LEVEL=info
LOG_PATH=/storage/logs
