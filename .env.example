# CookAI Configuration
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=cookai

# Yandex API
YANDEX_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/CookAI/public

# Session
SESSION_LIFETIME=120

# Mail (optional)
MAIL_FROM=noreply@cookai.local
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=/storage/uploads/

# Security
CSRF_TOKEN_NAME=csrf_token
